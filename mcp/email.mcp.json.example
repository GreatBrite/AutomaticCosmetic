{
  "mcpServers": {
    "freelance-email": {
      "command": "uvx",
      "args": ["mcp-email-server@latest", "stdio"],
      "env": {
        "MCP_EMAIL_SERVER_ACCOUNT_NAME": "freelance",
        "MCP_EMAIL_SERVER_FULL_NAME": "Your Name",
        "MCP_EMAIL_SERVER_EMAIL_ADDRESS": "freelance@example.com",
        "MCP_EMAIL_SERVER_USER_NAME": "freelance@example.com",
        "MCP_EMAIL_SERVER_PASSWORD": "app_password_here",
        "MCP_EMAIL_SERVER_IMAP_HOST": "imap.example.com",
        "MCP_EMAIL_SERVER_IMAP_PORT": "993",
        "MCP_EMAIL_SERVER_IMAP_SSL": "true",
        "MCP_EMAIL_SERVER_SMTP_HOST": "smtp.example.com",
        "MCP_EMAIL_SERVER_SMTP_PORT": "465",
        "MCP_EMAIL_SERVER_SMTP_SSL": "true",
        "MCP_EMAIL_SERVER_ENABLE_ATTACHMENT_DOWNLOAD": "false",
        "MCP_EMAIL_SERVER_SAVE_TO_SENT": "true"
      }
    }
  }
}

